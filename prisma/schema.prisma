generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  User
  Developer
  SEO
  SuperAdmin
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  role          Role     @default(User)
  signature     String?

  sessions Session[]
  accounts Account[]

  profile           Profile?
  reviews           Review[]
  newsPosts         NewsPost[]
  uploadedSubtitles Subtitle[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id           String    @id @default(uuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Profile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  displayName          String?
  bio                  String?
  avatar               String?
  bannerImage          String?
  country              String?
  pronouns             String?
  socialLinks          Json?
  animeCompletedCount  Int      @default(0)
  episodesWatchedCount Int      @default(0)
  totalWatchMinutes    Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AnimeType {
  TV
  Movie
  OVA
  ONA
  Special
  Drama
}

enum AnimeStatus {
  Airing
  Finished
  Upcoming
}

model Anime {
  id              String      @id @default(uuid())
  title           String
  description     String?
  type            AnimeType
  status          AnimeStatus
  image           String?
  episodesCount   Int?
  releaseDate     DateTime?
  ratingCount     Int         @default(0)
  popularityScore Float       @default(0)
  trendingScore   Float       @default(0)
  viewsCount      Int         @default(0)
  likesCount      Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  episodes   Episode[]
  characters AnimeCast[]
  tags       AnimeTag[]
  subtitle   Subtitle[]
  seasons    Season[]
  reviews    Review[]
  newsAnimes NewsAnime[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Season {
  id       String    @id @default(uuid())
  animeId  String
  number   Int
  title    String?
  anime    Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([animeId, number])
  @@index([animeId])
}

model Episode {
  id            String     @id @default(uuid())
  episodeNumber Int
  title         String
  description   String?
  airingDate    String
  animeId       String
  seasonId      String?
  subtitles     Subtitle[]

  anime  Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@unique([animeId, episodeNumber])
  @@index([animeId])
  @@index([seasonId])
}

enum SubtitleFormat {
  SRT
  ASS
  VTT
}

model Subtitle {
  id           String         @id @default(uuid())
  episodeId    String?
  animeId      String?
  language     String
  languageName String
  format       SubtitleFormat @default(SRT)
  fileUrl      String
  fileSizeKb   Int?
  isVerified   Boolean        @default(false)
  downloads    Int            @default(0)
  uploadedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  episode    Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  anime      Anime?   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([episodeId])
  @@index([animeId])
  @@index([language])
  @@index([uploadedById])
}


model Character {
  id     String  @id @default(uuid())
  name   String
  gender String?
  image  String?

  anime AnimeCast[]
  tags  CharacterTag[]
}

model AnimeCast {
  animeId     String
  characterId String
  role        String
  anime       Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([animeId, characterId])
  @@index([characterId])
}

model Tag {
  id         String         @id @default(uuid())
  name       String         @unique
  parentId   String?
  parent     Tag?           @relation("TagHierarchy", fields: [parentId], references: [id])
  subtags    Tag[]          @relation("TagHierarchy")
  anime      AnimeTag[]
  characters CharacterTag[]

  @@index([parentId])
}

model AnimeTag {
  animeId String
  tagId   String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([animeId, tagId])
  @@index([tagId])
}

model CharacterTag {
  characterId String
  tagId       String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([characterId, tagId])
  @@index([tagId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  title     String
  content   String
  rating    Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([animeId])
}

enum NewsCategory {
  Announcement
  Release
  Industry
  Event
  Other
}

model NewsPost {
  id          String       @id @default(uuid())
  authorId    String
  slug        String       @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    NewsCategory @default(Other)
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  viewsCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  relatedAnime NewsAnime[]

  @@index([isPublished, publishedAt])
  @@index([authorId])
}

model NewsAnime {
  newsPostId String
  animeId    String

  newsPost NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  anime    Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@id([newsPostId, animeId])
  @@index([animeId])
}
