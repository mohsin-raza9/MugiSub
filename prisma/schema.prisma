// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Better Auth Core Models
// ==========================================

enum Role {
  User
  Developer
  SEO
  SuperAdmin
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role    @default(User)
  signature     String?

  // Better Auth Relations
  sessions      Session[]
  accounts      Account[]

  // MugiSub Relations
  profile           Profile?
  playlists         Playlist[]
  mylist            MyListEntry[]
  favorites         Favorite[]
  watchHistory      WatchHistory[]
  reviews           Review[]
  newsPosts         NewsPost[]
  threads           ForumThread[]
  forumPosts        ForumPost[]
  editRequests      EditRequest[]
  uploadedSubtitles Subtitle[]
  notifications     Notification[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ==========================================
// User Profile Model
// ==========================================
// Separate from `User` so the auth-critical table stays lean.
// Holds everything that makes a "public profile page" possible.

model Profile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  displayName          String?
  bio                  String?
  avatar               String?
  bannerImage          String?
  country              String?
  pronouns             String?
  socialLinks          Json?    // { twitter, discord, website, ... }
  animeCompletedCount  Int      @default(0)
  episodesWatchedCount Int      @default(0)
  totalWatchMinutes    Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteTags Tag[] @relation("UserFavoriteTags")
}

// ==========================================
// Anime Catalog Models
// ==========================================

enum AnimeType {
  Movie
  Season
  Daram
}

enum AnimeStatus {
  Airing
  Finished
  Upcoming
}

model Anime {
  id            String      @id @default(uuid())
  title         String
  description   String?
  type          AnimeType
  status        AnimeStatus
  airDate       String?
  image         String?
  bannerImage   String?
  trailerUrl    String?
  episodesCount Int?
  rating        Float?
  ratingCount   Int         @default(0)
  average       Float?
  averageCount  Int         @default(0)
  viewsCount    Int         @default(0)
  popularity    Int         @default(0) // members who added this to a list
  trendingScore Float       @default(0) // recomputed periodically (views + recency decay)
  isFeatured    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  studios          AnimeStudio[]
  episodes         Episode[]
  characters       AnimeCharacter[]
  favorites        Favorite[]
  tags             AnimeTag[]
  reviews          Review[]
  collections      AnimeCollection[]
  playlistItems    PlaylistItem[]
  newsMentions     NewsAnime[]
  curatedListItems CuratedListItem[]
  subtitle          Subtitle[]
  seasons Season[]

  @@index([status])
  @@index([type])
  @@index([trendingScore])
  @@index([createdAt])
}

model Season {
  id      String    @id @default(uuid())
  animeId String
  number  Int             
  title   String?     
  description String?
  anime   Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@unique([animeId, number])
}

model Studio {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  image       String?
  anime       AnimeStudio[]
}

model AnimeStudio {
  animeId  String
  studioId String
  anime    Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  studio   Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@id([animeId, studioId])
}

model Episode {
  id            String          @id @default(uuid())
  episodeNumber Int
  title         String?
  description   String?
  airDate       String?
  animeId       String
  seasonId      String?
  mylistEntries MyListEntry[]
  subtitles     Subtitle[]
  watchHistory  WatchHistory[]

  anime         Anime           @relation(fields: [animeId], references: [id], onDelete: Cascade)
  season   Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@unique([animeId, episodeNumber])
}

// ==========================================
// Subtitles Models
// ==========================================
// The core of "MugiSub": standalone subtitle files per episode,

enum SubtitleFormat {
  SRT
  ASS
  VTT
}

model Subtitle {
  id           String         @id @default(uuid())
  episodeId    String?
  animeId      String?
  language     String         // ISO code, e.g. "en", "ur", "ja"
  languageName String         // "English", "Urdu", "Japanese"
  format       SubtitleFormat @default(SRT)
  fileUrl      String
  fileSizeKb   Int?
  isVerified   Boolean        @default(false)
  downloads    Int            @default(0)
  uploadedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  episode    Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  anime      Anime?   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([episodeId])
  @@index([animeId])
  @@index([language])
}

// ==========================================
// Characters & Staff Models
// ==========================================

model Character {
  id          String           @id @default(uuid())
  name        String
  gender      String?          // "female", "male", "other"
  description String?
  image       String?
  rating      Float?
  ratingCount Int              @default(0)
  trashPercent Float           @default(0.0) // waifu trash rating percentage
  haremCount  Int              @default(0)

  // Relations
  anime       AnimeCharacter[]
  favorites   Favorite[]
  tags        CharacterTag[]
}

model AnimeCharacter {
  animeId     String
  characterId String
  role        String          // "Main", "Supporting"
  vaId        String?         // Voice Actor Creator ID
  anime       Anime           @relation(fields: [animeId], references: [id], onDelete: Cascade)
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  voiceActor  Creator?        @relation(fields: [vaId], references: [id])

  @@id([animeId, characterId])
}

model Creator {
  id          String           @id @default(uuid())
  name        String
  role        String?          // e.g. "Voice Actor", "Director", "Author"
  bio         String?
  image       String?

  voicedCharacters AnimeCharacter[]
}

// ==========================================
// Collections & Tags Models
// ==========================================


model Collection {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  anime       AnimeCollection[]
}

model AnimeCollection {
  animeId      String
  collectionId String
  anime        Anime      @relation(fields: [animeId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([animeId, collectionId])
}

model Tag {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  parentId    String?
  parent      Tag?           @relation("TagHierarchy", fields: [parentId], references: [id])
  subtags     Tag[]          @relation("TagHierarchy")
  anime       AnimeTag[]
  characters  CharacterTag[]
  favoritedBy Profile[]      @relation("UserFavoriteTags")
}

model AnimeTag {
  animeId String
  tagId   String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([animeId, tagId])
}

model CharacterTag {
  characterId String
  tagId       String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([characterId, tagId])
}

// ==========================================
// Playlists Models
// ==========================================
// User-curated, shareable anime collections (different from MyListEntry,
// which tracks per-episode watch status).

model Playlist {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  coverImage  String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PlaylistItem[]
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  animeId    String
  note       String?
  position   Int      @default(0)
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  anime    Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([playlistId, animeId])
}

// ==========================================
// Mylist & Personal Activity Models
// ==========================================

model MyListEntry {
  id          String   @id @default(uuid())
  userId      String
  episodeId   String
  watchStatus String   // "completed", "watching", "on-hold", "plan-to-watch", "dropped"
  storageType String?  // "local", "cloud", "external"
  rating      Int?     // 1 to 10
  notes       String?
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
}

model WatchHistory {
  id            String   @id @default(uuid())
  userId        String
  episodeId     String
  progressSec   Int      @default(0)
  durationSec   Int?
  isCompleted   Boolean  @default(false)
  lastWatchedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId, lastWatchedAt])
}

model Favorite {
  id          String     @id @default(uuid())
  userId      String
  animeId     String?
  characterId String?

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime       Anime?     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId, characterId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  title     String
  content   String
  rating    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
}

// ==========================================
// News & Forums Models
// ==========================================

enum NewsCategory {
  Announcement
  Release
  Industry
  Event
  Other
}

model NewsPost {
  id          String       @id @default(uuid())
  authorId    String
  slug        String       @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?
  category    NewsCategory @default(Other)
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  viewsCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  relatedAnime NewsAnime[]

  @@index([isPublished, publishedAt])
}

model NewsAnime {
  newsPostId String
  animeId    String

  newsPost NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  anime    Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@id([newsPostId, animeId])
}

model ForumCategory {
  id          String        @id @default(uuid())
  title       String        @unique
  description String?
  threads     ForumThread[]
}

model ForumThread {
  id         String      @id @default(uuid())
  categoryId String
  creatorId  String
  title      String
  viewsCount Int         @default(0)
  createdAt  DateTime    @default(now())

  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creator    User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  posts      ForumPost[]
}

model ForumPost {
  id        String   @id @default(uuid())
  threadId  String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime @default(now())

  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    ForumPost?  @relation("PostReplies", fields: [parentId], references: [id])
  replies   ForumPost[] @relation("PostReplies")
}

// ==========================================
// Homepage / Curated Lists Models
// ==========================================
// Powers editorially-controlled sections like Trending, Popular,
// Latest Releases, Airing Soon, Editor's Picks, etc.
// (Dynamic versions of these can also be computed on the fly from
// Anime.viewsCount / popularity / trendingScore / createdAt / status.)

enum CuratedListType {
  Trending
  Popular
  LatestReleases
  AiringSoon
  RecentlyAdded
  TopRated
  EditorsPick
  StaffRecommended
}

model CuratedList {
  id        String          @id @default(uuid())
  type      CuratedListType
  title     String?
  updatedAt DateTime        @updatedAt
  createdAt DateTime        @default(now())

  items CuratedListItem[]

  @@unique([type, title])
}

model CuratedListItem {
  id            String      @id @default(uuid())
  curatedListId String
  animeId       String
  position      Int         @default(0)
  addedAt       DateTime    @default(now())

  curatedList CuratedList @relation(fields: [curatedListId], references: [id], onDelete: Cascade)
  anime       Anime       @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([curatedListId, animeId])
  @@index([curatedListId, position])
}

// ==========================================
// Notifications Model
// ==========================================

enum NotificationType {
  NewEpisode
  AnimeStatusChange
  ForumReply
  ReviewReply
  EditRequestUpdate
  System
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ==========================================
// Moderation & Edit Workflow Models
// ==========================================

model EditRequest {
  id            String   @id @default(uuid())
  userId        String
  entityType    String   // "anime", "character", "creator"
  entityId      String
  fieldChanged  String
  originalValue String?
  proposedValue String?
  status        String   // "pending", "approved", "rejected"
  reviewerId    String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}